import React, { useState, useEffect, useRef, useMemo, useCallback } from 'react';
import { View, Text, TouchableOpacity, StyleSheet, Animated, Dimensions, ScrollView } from 'react-native';
import { LinearGradient } from 'expo-linear-gradient';
import { NavigationProp } from '@react-navigation/native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { colors, spacing, borderRadius, typography } from '../constants/theme';
import { RootStackParamList } from '../../App';

export default function HomeScreen({ navigation }: { navigation: NavigationProp<RootStackParamList> }) {
  const [userName, setUserName] = useState('User');
  const [riskLevel, setRiskLevel] = useState('LOW');

  useEffect(() => {
    (async () => {
      const user = await AsyncStorage.getItem('safeguard_user');
      if (user) {
        const data = JSON.parse(user);
        if (data?.name) setUserName(data.name);
      }
    })();
  }, []);

  return (
    <View style={styles.container}>
      <LinearGradient colors={['#0A0A14', '#0E0A1A', '#0A0A14']} style={StyleSheet.absoluteFillObject} />
      <ScrollView contentContainerStyle={styles.scrollContent} showsVerticalScrollIndicator={false}>
        <Text style={styles.greeting}>Good Evening, {userName} 👋</Text>
        {/* Simplified Dashboard Components */}
        <View style={styles.sosCenterContainer}>
          <TouchableOpacity style={styles.sosButton} onPress={() => navigation.navigate('SOS')}>
            <LinearGradient colors={[colors.primary, '#FF0040', '#CC002A']} style={styles.sosGradient}>
              <Text style={styles.sosEmoji}>🆘</Text>
              <Text style={styles.sosLabel}>SOS</Text>
            </LinearGradient>
          </TouchableOpacity>
        </View>
      </ScrollView>
    </View>
  );
}

